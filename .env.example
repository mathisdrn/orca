# [README] Copy this file as .env and replace {PROJECT_ROOT} with the absolute path to the project. 

# Path to the dlt configuration directory
DLT_CONFIG_FOLDER={PROJECT_ROOT}/ingestion/.dlt

# Path to Dagster directory
DAGSTER_HOME={PROJECT_ROOT}/orchestration/dagster_home

# Path to database storage for dbt.
# DBT_DUCKDB_DATA_PATH is derived from DBT_DUCKDB_PATH: same path without 'ducklake:' prefix, with '.files/' appended.
DBT_DUCKDB_PATH=ducklake:{PROJECT_ROOT}/storage/orca.ducklake
DBT_DUCKDB_DATA_PATH={PROJECT_ROOT}/storage/orca.ducklake.files/